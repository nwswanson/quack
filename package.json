{
  "private": true,
  "scripts": {
    "admin2:css": "tailwindcss -i ./internal/admin2/assets/admin.css -o ./internal/admin2/assets/dist/admin.css --minify",
    "admin2:js": "mkdir -p ./internal/admin2/assets/dist && cp ./node_modules/htmx.org/dist/htmx.min.js ./internal/admin2/assets/dist/htmx.min.js && cp ./node_modules/alpinejs/dist/cdn.min.js ./internal/admin2/assets/dist/alpine.min.js",
    "admin2:assets": "npm run admin2:css && npm run admin2:js"
  },
  "dependencies": {
    "alpinejs": "^3.15.2",
    "htmx.org": "^2.0.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  }
}
